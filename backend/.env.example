DATABASE_URL=postgresql://vat:vat@localhost:5432/vatdb
JWT_SECRET=change-me-in-production
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Redis (BullMQ queue)
# Docker Compose: redis://redis:6379  |  Local bare-metal: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# MinIO / S3-compatible blob storage
# Docker Compose: http://minio:9000  |  Production: your S3-compatible endpoint
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=vat-documents
