<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-02-25" version="21.0.0">
  <diagram name="Container Topology" id="02-container-topology">
    <mxGraphModel dx="1200" dy="850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ── Title ── -->
        <mxCell id="title" value="VAT Platform — Docker Compose Container Topology"
          style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=17;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="150" y="10" width="900" height="32" as="geometry"/>
        </mxCell>

        <!-- ── Docker Compose network boundary ── -->
        <mxCell id="dockerNet" value="docker compose network · vat-platform"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#888888;strokeDasharray=8,4;strokeWidth=2;fontSize=13;fontStyle=1;verticalAlign=top;arcSize=2;"
          vertex="1" parent="1">
          <mxGeometry x="30" y="55" width="1140" height="710" as="geometry"/>
        </mxCell>

        <!-- ── frontend ── -->
        <mxCell id="frontend" value="&lt;b&gt;frontend&lt;/b&gt;&lt;br/&gt;custom multi-stage Dockerfile&lt;br/&gt;&lt;i&gt;dev target&lt;/i&gt;: Vite hot-reload  →  host :5173&lt;br/&gt;&lt;i&gt;prod target&lt;/i&gt;: nginx static serve  →  host :80&lt;br/&gt;bind mount (dev): ./frontend/src → /app/src"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;arcSize=8;"
          vertex="1" parent="1">
          <mxGeometry x="410" y="95" width="380" height="115" as="geometry"/>
        </mxCell>

        <!-- ── backend ── -->
        <mxCell id="backend" value="&lt;b&gt;backend&lt;/b&gt;&lt;br/&gt;custom multi-stage Dockerfile · NestJS 11 · Node.js 22 LTS&lt;br/&gt;&lt;i&gt;dev target&lt;/i&gt;: ts-node hot-reload  ·  &lt;i&gt;prod target&lt;/i&gt;: compiled JS&lt;br/&gt;host :3000  ·  Swagger /api/docs (dev)&lt;br/&gt;bind mounts (dev): ./backend/src · ./backend/prisma&lt;br/&gt;depends_on: postgres (healthy) · redis (healthy)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;arcSize=8;"
          vertex="1" parent="1">
          <mxGeometry x="270" y="285" width="660" height="130" as="geometry"/>
        </mxCell>

        <!-- ── postgres ── -->
        <mxCell id="postgres" value="&lt;b&gt;postgres&lt;/b&gt;&lt;br/&gt;postgres:16-alpine&lt;br/&gt;host :5432 → container :5432&lt;br/&gt;vol: postgres_data&lt;br/&gt;healthcheck: pg_isready"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;arcSize=8;"
          vertex="1" parent="1">
          <mxGeometry x="55" y="510" width="235" height="120" as="geometry"/>
        </mxCell>

        <!-- ── redis ── -->
        <mxCell id="redis" value="&lt;b&gt;redis&lt;/b&gt;&lt;br/&gt;redis:7-alpine&lt;br/&gt;host :6379 → container :6379&lt;br/&gt;vol: redis_data&lt;br/&gt;healthcheck: redis-cli ping"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;arcSize=8;"
          vertex="1" parent="1">
          <mxGeometry x="340" y="510" width="235" height="120" as="geometry"/>
        </mxCell>

        <!-- ── minio ── -->
        <mxCell id="minio" value="&lt;b&gt;minio&lt;/b&gt;&lt;br/&gt;minio/minio:latest&lt;br/&gt;host :9000 → S3 API&lt;br/&gt;host :9001 → web console (dev only)&lt;br/&gt;vol: minio_data  ·  healthcheck: /minio/health/live"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;arcSize=8;"
          vertex="1" parent="1">
          <mxGeometry x="625" y="510" width="280" height="120" as="geometry"/>
        </mxCell>

        <!-- ── minio-init ── -->
        <mxCell id="minioInit" value="&lt;b&gt;minio-init&lt;/b&gt;&lt;br/&gt;minio/mc:latest&lt;br/&gt;one-shot container&lt;br/&gt;creates bucket: vat-documents&lt;br/&gt;depends_on: minio (healthy)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;arcSize=8;strokeDasharray=4,3;"
          vertex="1" parent="1">
          <mxGeometry x="955" y="510" width="185" height="120" as="geometry"/>
        </mxCell>

        <!-- ── Volumes + prod overrides annotation ── -->
        <mxCell id="volNote" value="Named volumes: postgres_data · redis_data · minio_data (persist between restarts) · Production overrides (docker-compose.prod.yml): target=production builds, no bind mounts, secrets from env vars, minio console port closed"
          style="text;html=1;strokeColor=#82b366;fillColor=#f0fff0;fontSize=11;align=center;strokeDasharray=3,3;"
          vertex="1" parent="1">
          <mxGeometry x="55" y="668" width="1075" height="30" as="geometry"/>
        </mxCell>

        <!-- ── Edges ── -->
        <!-- frontend → backend (HTTP proxy) -->
        <mxCell id="e_fe_be" value="HTTP / Vite proxy&lt;br/&gt;VITE_API_TARGET=http://backend:3000"
          style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6c8ebf;fontColor=#6c8ebf;fontSize=11;"
          edge="1" source="frontend" target="backend" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- backend → postgres -->
        <mxCell id="e_be_pg" value="Prisma ORM&lt;br/&gt;DATABASE_URL"
          style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#82b366;fontColor=#5a7c50;fontSize=11;"
          edge="1" source="backend" target="postgres" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- backend → redis -->
        <mxCell id="e_be_rd" value="BullMQ / ioredis&lt;br/&gt;REDIS_URL"
          style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#82b366;fontColor=#5a7c50;fontSize=11;"
          edge="1" source="backend" target="redis" parent="1">
