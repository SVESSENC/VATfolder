        </mxCell>

        <!-- backend → minio -->
        <mxCell id="e_be_mn" value="@aws-sdk/client-s3&lt;br/&gt;MINIO_ENDPOINT"
          style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#82b366;fontColor=#5a7c50;fontSize=11;"
          edge="1" source="backend" target="minio" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- minio-init → minio (one-shot depends_on) -->
        <mxCell id="e_mi_mn" value="mc alias + mb&lt;br/&gt;(one-shot init)"
          style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#b85450;fontColor=#b85450;fontSize=11;dashed=1;"
          edge="1" source="minioInit" target="minio" parent="1">
