        </mxCell>
        <mxCell id="e_audit_pg" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d6b656;" edge="1" source="modAudit" target="prisma" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ── Edges: modules → adapters ── -->
        <mxCell id="e_auth_mitid" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#666666;" edge="1" source="modAuth" target="adpMitid" parent="1">
